# Supabase project URL and Service Role Key (use SERVICE_ROLE_KEY only on trusted server)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Base URL where the signing frontend page will live (used to build link)
SIGN_PAGE_BASE_URL=https://seu-site.com/assinatura

# Storage bucket name for termos (create this bucket in Supabase Storage)
TERMS_BUCKET=termos

# Port for this service
PORT=4000
